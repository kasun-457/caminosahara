rules_version = '2';

// ══════════════════════════════════════════════════════════════════════════════
//  Firestore 보안 규칙
//  Firebase 콘솔 → Firestore Database → 규칙 탭 → 아래 내용을 붙여넣고 [게시]
// ══════════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── /trips/{tripId} ─────────────────────────────────────────────
    //  여행 문서. memberIds 배열에 포함된 사용자만 읽기/수정/삭제 가능.
    match /trips/{tripId} {

      // 읽기 권한 분리: 
      // list(전체 검색)는 기존 멤버만 가능하게 하여 목록 유출을 막고,
      // get(단일 조회)은 로그인한 사용자가 초대 링크의 tripId로 접근할 수 있게 허용합니다.
      allow list: if request.auth != null && request.auth.uid in resource.data.memberIds;
      allow get: if request.auth != null;

      // 생성: 기존과 동일하게 유지
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerId
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.keys().hasAll([
             'title', 'destination', 'startDate', 'endDate',
             'color', 'ownerId', 'memberIds', 'shareCode',
             'days', 'createdAt'
           ])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 100
        && request.resource.data.destination is string
        && request.resource.data.destination.size() <= 100
        && request.resource.data.startDate is string
        && request.resource.data.endDate is string
        && request.resource.data.color is string
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() <= 20
        && request.resource.data.days is list
        && request.resource.data.shareCode is string;

      // 수정: 기존 멤버의 업데이트 허용 OR 새로운 멤버가 배열에 자신의 UID만 딱 추가하는 동작 허용
      allow update: if request.auth != null
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.memberIds.size() <= 20
        && (
          // 1) 기존 멤버인 경우 자유롭게 수정 가능
          request.auth.uid in resource.data.memberIds
          ||
          // 2) 아직 멤버가 아닌 경우: memberIds 배열에 오직 자신의 UID 하나만 추가하고 다른 필드는 변경 안 함
          (
            request.resource.data.memberIds.hasAll(resource.data.memberIds) &&
            request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1 &&
            request.auth.uid in request.resource.data.memberIds &&
            request.resource.data.title == resource.data.title &&
            request.resource.data.destination == resource.data.destination &&
            request.resource.data.startDate == resource.data.startDate &&
            request.resource.data.endDate == resource.data.endDate &&
            request.resource.data.color == resource.data.color &&
            request.resource.data.shareCode == resource.data.shareCode &&
            request.resource.data.days == resource.data.days
          )
          ||
          // 3) 기존 멤버가 자신의 UID만 memberIds에서 제거하는 경우 (회원탈퇴 시 공유 여행에서 나가기)
          (
            request.auth.uid in resource.data.memberIds &&
            resource.data.memberIds.hasAll(request.resource.data.memberIds) &&
            request.resource.data.memberIds.size() == resource.data.memberIds.size() - 1 &&
            !(request.auth.uid in request.resource.data.memberIds) &&
            request.resource.data.title == resource.data.title &&
            request.resource.data.destination == resource.data.destination &&
            request.resource.data.startDate == resource.data.startDate &&
            request.resource.data.endDate == resource.data.endDate &&
            request.resource.data.color == resource.data.color &&
            request.resource.data.shareCode == resource.data.shareCode &&
            request.resource.data.days == resource.data.days
          )
        );

      // 삭제: 기존과 동일하게 방장(ownerId)만 가능
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.ownerId;
    }
  }
}