rules_version = '2';

// ══════════════════════════════════════════════════════════════════════════════
//  Firestore 보안 규칙
//  Firebase 콘솔 → Firestore Database → 규칙 탭 → 아래 내용을 붙여넣고 [게시]
// ══════════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── /trips/{tripId} ─────────────────────────────────────────────
    //  여행 문서. memberIds 배열에 포함된 사용자만 읽기/수정/삭제 가능.
    match /trips/{tripId} {

      // 읽기: 멤버만 가능
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberIds;

      // 생성: 본인이 ownerId이고, 본인을 memberIds에 포함하며,
      //       필수 필드를 모두 갖춘 경우만 허용
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerId
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.keys().hasAll([
             'title', 'destination', 'startDate', 'endDate',
             'color', 'ownerId', 'memberIds', 'shareCode',
             'days', 'createdAt'
           ])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 100
        && request.resource.data.destination is string
        && request.resource.data.destination.size() <= 100
        && request.resource.data.startDate is string
        && request.resource.data.endDate is string
        && request.resource.data.color is string
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() <= 20
        && request.resource.data.days is list
        && request.resource.data.shareCode is string;

      // 수정: 멤버만 가능. ownerId·createdAt 변경 불가.
      allow update: if request.auth != null
        && request.auth.uid in resource.data.memberIds
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.memberIds.size() <= 20;

      // 삭제: ownerId만 가능
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.ownerId;
    }

    // 그 외 모든 문서 접근 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
